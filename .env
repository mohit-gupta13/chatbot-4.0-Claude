# AWS Bedrock Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here

# Claude Model Configuration
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514

# Vector Database Configuration
CHROMA_DB_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Data File Path
BOOKING_FILE=Existing Booking.xlsx

# Instructions:
# 1. Replace AWS credentials with your actual values
# 2. Ensure AWS Bedrock is enabled in your region
# 3. Request access to Claude Sonnet 4.5 if needed
# 4. Keep this file secure - do not commit to version control
